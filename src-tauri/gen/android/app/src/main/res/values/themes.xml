<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- The app is dark-only by design (cinematic viewing identity) — both day and
         night variants pin the brand ground so launch, the keyboard transition, and
         the edge-to-edge system bars never flash a mismatched surface. -->
    <style name="Theme.unstation_android" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/unstation_ground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Dark surface ⇒ light system-bar icons. -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>
